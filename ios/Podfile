# 1. Flutter SDK yolunu sistemden (ENV) veya yapılandırmadan dinamik olarak alalım
def flutter_root
  # Codemagic ve çoğu CI/CD platformu bu değişkeni otomatik sağlar
  return ENV['FLUTTER_ROOT'] if ENV['FLUTTER_ROOT']

  # Yerel geliştirme ortamı için Generated.xcconfig kontrolü
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  if File.exist?(generated_xcode_build_settings_path)
    File.foreach(generated_xcode_build_settings_path) do |line|
      matches = line.match(/\AFLUTTER_ROOT=(.*)\z/)
      return matches[1].strip if matches
    end
  end

  # Hiçbiri bulunamazsa hata fırlatmak yerine varsayılan Flutter yolunu tahmin etmeyi dene
  File.expand_path(File.join('..', '..', '..'), __FILE__)
end

# 2. podhelper.rb dosyasını yükle
# Hata aldığınız 'require' satırı yerine bu güvenli yükleme yöntemini kullanıyoruz
podhelper_path = File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'podhelper')

if File.exist?(podhelper_path + '.rb')
  require podhelper_path
else
  # Eğer ana yol bulunamazsa yerel yedek yolu dene
  local_helper = File.expand_path(File.join('..', 'Flutter', 'podhelper.rb'), __FILE__)
  if File.exist?(local_helper)
    require local_helper
  else
    raise "podhelper bulunamadı! Lütfen FLUTTER_ROOT değişkenini kontrol edin."
  end
end

# Proje Ayarları
platform :ios, '14.0'

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Flutter pod'larını yükle
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

# 3. Post Install Hook - Özel ayarları koruyan bölüm
post_install do |installer|
  installer.pods_project.targets.each do |target|
    # Flutter'ın kendi build ayarlarını ekle
    flutter_additional_ios_build_settings(target)
    
    target.build_configurations.each do |config|
      # Proje gereksinimlerine göre sabitlenen ayarlar
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      
      # Firebase/Header hatalarını önlemek için
      config.build_settings['GCC_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER'] = 'NO'
    end
  end
end