# 1. Flutter SDK yolunu sistemden (ENV) veya yapılandırmadan dinamik olarak alalım
def flutter_root
  # Codemagic ortamında bu değişken yolu otomatik sağlar
  return ENV['FLUTTER_ROOT'] if ENV['FLUTTER_ROOT']

  # Yerel çalışma ortamı (VS Code/Android Studio) için kontrol
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  if File.exist?(generated_xcode_build_settings_path)
    File.foreach(generated_xcode_build_settings_path) do |line|
      matches = line.match(/\AFLUTTER_ROOT=(.*)\z/)
      return matches[1].strip if matches
    end
  end

  # Eğer hiçbir veri bulunamazsa varsayılan üst dizini dene
  File.expand_path(File.join('..', '..', '..'), __FILE__)
end

# 2. podhelper.rb dosyasını yükle (Eski require satırı yerine bu güvenli blok kullanılır)
f_root = flutter_root
if f_root
  podhelper_path = File.join(f_root, 'packages', 'flutter_tools', 'bin', 'podhelper.rb')
  if File.exist?(podhelper_path)
    load podhelper_path
  else
    # CI ortamı için yedek yerel yol denemesi
    load File.expand_path(File.join('..', 'Flutter', 'podhelper.rb'), __FILE__)
  end
else
  # Flutter root bulunamazsa son çare yerel yükleme
  load File.expand_path(File.join('..', 'Flutter', 'podhelper.rb'), __FILE__)
end

# --- Proje Ayarları ---
platform :ios, '14.0'

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Flutter pod'larını yükle
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

# 3. Post Install Hook - Özel ayarlarınızı koruyan bölüm
post_install do |installer|
  installer.pods_project.targets.each do |target|
    # Flutter'ın kendi build ayarlarını ekle
    flutter_additional_ios_build_settings(target)
    
    target.build_configurations.each do |config|
      # Belirlediğiniz özel ayarlar (iOS 14.0 ve Bitcode kapatma)
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      
      # Firebase ve diğer paketlerdeki header hatalarını önleme
      config.build_settings['GCC_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER'] = 'NO'
    end
  end
end