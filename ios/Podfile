# Flutter yardımcı scriptini yüklemek için dinamik yol belirleme
def flutter_root
  # 1. Önce Generated.xcconfig dosyasını kontrol et
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  
  if File.exist?(generated_xcode_build_settings_path)
    File.foreach(generated_xcode_build_settings_path) do |line|
      matches = line.match(/\AFLUTTER_ROOT=(.*)\z/)
      return matches[1].strip if matches
    end
  end

  # 2. Eğer dosyadan bulamazsa (Codemagic gibi ortamlar için) sistem değişkenine bak
  # Bu kısım hatayı kesin olarak çözen kısımdır.
  return ENV['FLUTTER_ROOT'] if ENV['FLUTTER_ROOT']
  
  # 3. Fallback: Eğer hiçbiri yoksa standart dizine bak
  File.expand_path(File.join('..', '..', '..'), __FILE__)
end

# Hata veren require satırı yerine bu güvenli yüklemeyi kullanıyoruz
podhelper_path = File.expand_path(File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'podhelper'), __FILE__)

if File.exist?(podhelper_path)
  require podhelper_path
else
  # En son çare: Flutter'ın sistemdeki ana yolundan direkt çek
  require File.expand_path(File.join(ENV['FLUTTER_ROOT'] || '..', 'packages', 'flutter_tools', 'bin', 'podhelper'), __FILE__)
end

platform :ios, '14.0'

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    target.build_configurations.each do |config|
      # Proje gereksinimlerini koruyoruz
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
    end
  end
end