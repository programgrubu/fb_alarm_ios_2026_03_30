# Flutter'ın sistemdeki yerini dinamik ve güvenli bulan fonksiyon
def flutter_root
  # 1. ÖNCE: Codemagic gibi CI ortamları için sistem değişkenine bak (Hatayı çözen ana kısım)
  if ENV['FLUTTER_ROOT']
    return ENV['FLUTTER_ROOT']
  end

  # 2. SONRA: Yerel bilgisayarınızdaki Generated.xcconfig dosyasını kontrol et
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  if File.exist?(generated_xcode_build_settings_path)
    File.foreach(generated_xcode_build_settings_path) do |line|
      matches = line.match(/\AFLUTTER_ROOT=(.*)\z/)
      return matches[1].strip if matches
    end
  end

  # 3. EN SON: Hiçbiri yoksa varsayılan üst dizine bak
  File.expand_path(File.join('..', '..', '..'), __FILE__)
end

# Dinamik yolu kullanarak podhelper'ı güvenli şekilde yükle
podhelper_path = File.expand_path(File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'podhelper'), __FILE__)

if File.exist?(podhelper_path)
  require podhelper_path
else
  # Dosya bulunamazsa hatayı anlamak için yolu ekrana yazdırır
  raise "podhelper bulunamadı! Lütfen önce 'flutter pub get' çalıştırın. Aranan yol: #{podhelper_path}"
end

platform :ios, '14.0'

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    target.build_configurations.each do |config|
      # Mevcut proje gereksinimlerinizi noktasına dokunmadan koruyoruz
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
    end
  end
end